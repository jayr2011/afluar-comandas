# Supabase (OBRIGATÓRIO - sem fallback)
# Obtenha em: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co  # Exemplo: https://xyzabc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui  # Exemplo: eyJhbGciOiJIUzI1NiIs...

# Chave de serviço (OBRIGATÓRIO para operações admin)
# NUNCA exponha no código do frontend
# Apenas para uso server-side (API routes)
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_aqui  # Exemplo: eyJhbGciOiJIUzI1NiIs...

# Imagens (domínio do Supabase Storage)
SUPABASE_HOST=seu_projeto.supabase.co

# API Admin - Chave para proteger rotas de escrita (POST, PUT, DELETE)
# Use uma chave forte e aleatória: openssl rand -hex 32
ADMIN_API_KEY=sua_chave_admin_aqui  # Exemplo: a1b2c3d4e5f6...

# WhatsApp
# Configure sua API de WhatsApp
WHATSAPP_API_TOKEN=token-da-api-escolhida
COZINHA_NUMBER=5511999999999
