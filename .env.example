# Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/developers/pt/docs
MP_ACCESS_TOKEN=TEST-seu_token_aqui
MP_PUBLIC_KEY=TEST-sua_chave_publica_aqui

# Chave pública para o Brick no navegador (obrigatório NEXT_PUBLIC_)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-sua_chave_publica_aqui

# Supabase
# Obtenha em: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# Chave de serviço (NUNCA exponha no código do frontend)
# Apenas para uso server-side (API routes)
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_aqui

# Imagens (domínio do Supabase Storage)
SUPABASE_HOST=seu_projeto.supabase.co

# WhatsApp
# Configure sua API de WhatsApp
WHATSAPP_API_TOKEN=token-da-api-escolhida
COZINHA_NUMBER=5511999999999
